# CasaIA — variables de entorno
# Copia este archivo a .env y completa los valores:
#   cp .env.example .env

# Backend NestJS (misma red WiFi que el celular; NO uses localhost en dispositivo físico)
# Ejemplo: http://192.168.1.90:8000
EXPO_PUBLIC_API_BASE_URL=http://192.168.1.90:8000

# Google Cloud Console → APIs & Services → Credentials
# Habilitar: Maps SDK for Android + Maps SDK for iOS
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# Supabase → Project Settings → API
# En Expo usa EXPO_PUBLIC_* (NO VITE_*). La publishable key va en ANON_KEY:
#   URL:  https://TU_REF.supabase.co
#   Key:  sb_publishable_...  (nuevo)  o  eyJ...  (anon JWT clásico)
EXPO_PUBLIC_SUPABASE_URL=https://TU_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_REEMPLAZA_O_usa_eyJ_anon_key
